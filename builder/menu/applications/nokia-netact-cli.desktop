[Desktop Entry]
Version=1.0
Type=Application
Name=Nokia NetAct CLI
Comment=Connect to Nokia NetAct OSS/BSS via SSH (requires NetAct server access)
Exec=xfce4-terminal --hold --title="Nokia NetAct CLI" -x bash -c "echo 'Nokia NetAct CLI'; echo ''; echo 'Usage: ssh <user>@<netact-host>'; echo 'Or use the NetAct web portal at https://<netact-host>/netact/'; echo ''; read -p 'Press Enter to exit...'"
Icon=network-server
Terminal=false
Categories=TelcoSec-Core;
