[Desktop Entry]
Version=1.0
Type=Application
Name=Kalibrate RTL
Comment=Calculate RTL-SDR frequency offset against GSM base stations
Exec=gnome-terminal --title "Kalibrate RTL" -- bash -c "kal -h; echo ''; read -p 'Press Enter to exit...'"
