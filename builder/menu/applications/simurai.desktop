[Desktop Entry]
Version=1.0
Type=Application
Name=SIMurai (swsim)
Comment=Software SIM emulator — emulate a full UICC/SIM card via TCP/IP and PC/SC
Exec=gnome-terminal --window-with-profile=e5c6b891-2d4a-4e7f-8c10-b4f3a1e9d027 --title "SIMurai" -- bash -c "echo 'SIMurai — software SIM platform'; echo ''; echo 'Usage: simurai <listen-ip> <port> <filesystem.json>'; echo '       swicc-pcsc is registered with pcscd as a virtual IFD driver.'; echo ''; echo 'Source: /opt/telcosec/simurai'; echo ''; read -p 'Press Enter to exit...'"
Icon=smartcard
Terminal=false
Categories=TelcoSec-SIM;
