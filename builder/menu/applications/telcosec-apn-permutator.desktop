[Desktop Entry]
Version=1.0
Type=Application
Name=APN Permutator
Comment=Generate APN name permutations for carrier network enumeration
Exec=xfce4-terminal --hold --title="APN Permutator" -x bash -c 'telcosec-apn-permutator --help; echo; read -rp "Press Enter to close..."'
